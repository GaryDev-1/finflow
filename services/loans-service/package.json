{
  "name": "@finflow/loans-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "dotenv -o -e ../../.env -- tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "dotenv -o -e ../../.env -- tsx src/db/migrate.ts",
    "seed": "dotenv -o -e ../../.env -- tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "express": "5.2.1",
    "pg": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/pg": "^8.0.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "dotenv-cli": "^8.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "5.8.3",
    "vitest": "^3.0.0"
  }
}
